# AI News Archive Environment Variables Template
# 아래 항목들을 실제 값으로 치환하고 `.env` 이름으로 저장하세요.

# [필수] 텔레그램 봇 API 토큰 (@BotFather 에서 발급)
TELEGRAM_BOT_TOKEN="123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ"

# [필수] 텔레그램 발송 대상 (공지 채널용 ID 권장)
# 예: 개인 챗방(숫자), 혹은 채널(@ai_news_archive_korea)
TELEGRAM_CHAT_ID="@your_telegram_channel_or_chat_id"
